
# --- AI Smart Shield Trust Route - Environment Configuration ---

# 1. Project Info
PROJECT_NAME="AI Smart Shield Trust Route"
ENVIRONMENT=production
DEBUG=False

# 2. Database
# Default is SQLite for local dev, use PostgreSQL for production
# DATABASE_URL=postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///./smartshield.db

# 3. Essential API Keys (REQUIRED FOR REAL DATA)
# Get Google Maps key at: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Optional: Secondary routing fallbacks
GRAPHHOPPER_API_KEY=your_graphhopper_key
POSITIONSTACK_API_KEY=your_positionstack_key

# 4. Auth & Security
# Generate a strong secret key: openssl rand -hex 32
SECRET_KEY=generate_a_secure_random_string_here
JWT_SECRET_KEY=generate_another_secure_random_string_here

# 5. Communication (For SOS Alerts)
# Using Gmail SMTP? Use an App Password if 2FA is on
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=your_email@gmail.com
EMERGENCY_EMAIL=dharunika0708@gmail.com

# 6. SMS Alerts (Optional - Twilio)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_number
EMERGENCY_PHONE=+919876543210

# 7. Server Settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
